DATABASE_HOST='document_list_db'
DATABASE_PORT=17232
DATABASE_USER='document_list_user'
DATABASE_PASSWORD='document_list_pass'
DATABASE_NAME='document_list_primary'
DATABASE_NAME_SECONDARY='document_list_secondary'
DATABASE_USE_SSL='false'

REDIS_HOST='document-list-redis'
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD='document-list-redis-pass'
REDIS_USE_SSL=true

MIGRATOR_HOST='document-list-migrator'

FILE_LINES_SPLIT=1000000

# Worker batch sizes (rows per COPY pipeline call)
MIGRATOR_BATCH_ROWS_DNI=100000
MIGRATOR_BATCH_ROWS_RUC=50000

# Supervisor / dynamic concurrency (AIMD)
MIGRATOR_INITIAL_CONCURRENCY=4
MIGRATOR_MIN_CONCURRENCY=2
# Si no se setea, se calcula como min(max_connections - HEADROOM, 16)
# MIGRATOR_MAX_CONCURRENCY=16
MIGRATOR_CONNECTION_HEADROOM=5
MIGRATOR_PROBE_INTERVAL_MS=15000
MIGRATOR_PROBE_THRESHOLD_PCT=5

# Si un worker no reporta progress en este lapso, el supervisor lo termina
MIGRATOR_WORKER_LIVENESS_TIMEOUT_MS=300000

# Grace period para drenar workers en SIGTERM antes de terminate() forzado
MIGRATOR_SHUTDOWN_GRACE_MS=60000

DOCKER_REGISTRY_URL="docker.io"